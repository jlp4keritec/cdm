# Copie ce fichier en ".env" et remplis les valeurs.
# Le vrai .env ne doit JAMAIS être publié sur GitHub.

# Clé d'accès à football-data.org (matchs et scores)
FOOTBALL_API_KEY=ta_cle_football_data_org

# Clé de sécurité des sessions (mets une longue chaîne aléatoire)
SESSION_SECRET=une_longue_chaine_aleatoire_privee
